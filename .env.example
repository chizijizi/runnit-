# === RUNNIT — Environment Variables ===
# Kopiraj ovu datoteku u .env i popuni vrijednosti

# Baza podataka (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/runnit

# JWT autentikacija
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Aplikacija
APP_NAME=RUNNIT
APP_VERSION=0.1.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
